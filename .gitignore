# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Include the example tfvars file for documentation
!terraform.auto.tfvars.example

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore the dependency lock file (regenerated by terraform init)
.terraform.lock.hcl

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Ignore plan output files
*tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# ignore notes-during-refactoring folder
notes-during-refactoring/

# Bulk run demo outputs
/demo-runs/

# Environment files
.env

# OS files
.DS_Store
.copilot/config.json
.copilot/logs/*
